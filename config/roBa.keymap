#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#define MOUSE 4
#define SCROLL 5
#define NUM 6
#define MAC_DEFAULT 7
#define MAC_FUNC 8
#define MAC_SCROLL 9
#define ZMK_POINTING_DEFAULT_SCRL_VAL 100

&mt {
    flavor = "balanced";
    quick-tap-ms = <0>;
};

&trackball {
    automouse-layer = <4>;
    scroll-layers = <5 9>;
};

&sl { release-after-ms = <450>; }; // ダブルクリックに必要な時間を設定
/ {
    combos {
        compatible = "zmk,combos";

        SELECT_BT {
            bindings = <&bt BT_SEL 0>;
            key-positions = <22 28>;
        };

        BT_SELECT1 {
            bindings = <&bt BT_SEL 1>;
            key-positions = <23 29>;
        };

        SELECT_BT2 {
            bindings = <&bt BT_SEL 2>;
            key-positions = <24 30>;
        };

        SELECT_BT3 {
            bindings = <&bt BT_SEL 3>;
            key-positions = <25 31>;
        };

        SELECT_BT4 {
            bindings = <&bt BT_SEL 4>;
            key-positions = <26 32>;
        };

        clear_bluetooth {
            bindings = <&bt BT_CLR_ALL>;
            key-positions = <15 27 16 28>;
        };

        // インデント（S+D / D+F）

        TAB_COMBO {
            bindings = <&kp TAB>;
            key-positions = <11 12>;
            layers = <0 7>;
            require-prior-idle-ms = <125>;
        };

        SHIFT_TAB_COMBO {
            bindings = <&kp LS(TAB)>;
            key-positions = <12 13>;
            layers = <0 7>;
            require-prior-idle-ms = <125>;
        };

        // 保存（S+F）

        SAVE {
            bindings = <&kp LC(S)>;
            key-positions = <11 13>;
            layers = <0>;
            require-prior-idle-ms = <125>;
        };

        // アンドゥ（X+C）

        combo_undo {
            bindings = <&kp LC(Z)>;
            key-positions = <23 24>;
            layers = <0>;
            require-prior-idle-ms = <125>;
        };

        // コメントトグル（J+K）

        COMMENT_TOGGLE {
            bindings = <&kp LC(FSLH)>;
            key-positions = <31 30>;
            layers = <0>;
            require-prior-idle-ms = <125>;
        };

        // Escape（Q+W）

        ESC_COMBO {
            bindings = <&kp ESC>;
            key-positions = <0 1>;
            layers = <0 7>;
            require-prior-idle-ms = <125>;
        };

        // Mac専用コンボ（MAC_DEFAULT layer 7 がベースの時のみ発火）

        MAC_SAVE {
            bindings = <&kp LG(S)>;
            key-positions = <11 13>;
            layers = <7>;
            require-prior-idle-ms = <125>;
        };

        MAC_UNDO {
            bindings = <&kp LG(Z)>;
            key-positions = <23 24>;
            layers = <7>;
            require-prior-idle-ms = <125>;
        };

        MAC_COMMENT_TOGGLE {
            bindings = <&kp LG(FSLH)>;
            key-positions = <30 31>;
            layers = <7>;
            require-prior-idle-ms = <125>;
        };

        LEFT_CLICK {
            bindings = <&mkp LCLK>;
            key-positions = <18 19>;
        };

        RIGHT_CLICK {
            bindings = <&mkp RCLK>;
            key-positions = <19 20>;
        };
    };

    macros {
        to_layer_0: to_layer_0 {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&to 0 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
            label = "TO_LAYER_0";
        };

        to_mac_layer: to_mac_layer {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&to 7 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
            label = "TO_MAC_LAYER";
        };

        // コーディング用アロー記号マクロ

        arrow: arrow {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp MINUS &kp GT>;
            label = "ARROW";
        };

        fat_arrow: fat_arrow {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp EQUAL &kp GT>;
            label = "FAT_ARROW";
        };

        not_eq: not_eq {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp EXCLAMATION &kp EQUAL>;
            label = "NOT_EQ";
        };

        macros {
            mkp_exit_AML: mkp_exit_AML {
                compatible = "zmk,behavior-macro-one-param";
                #binding-cells = <1>;
                bindings =
                    <&macro_press>,
                    <&macro_param_1to1 &mkp MACRO_PLACEHOLDER>,
                    <&macro_pause_for_release>,
                    <&macro_release>,
                    <&macro_param_1to1 &mkp MACRO_PLACEHOLDER>,
                    <&macro_tap>,
                    <&sl MOUSE>;

                label = "MKP_EXIT_AML";
            };
        };
    };

    behaviors {
        lt_to_layer_0: lt_to_layer_0 {
            compatible = "zmk,behavior-hold-tap";
            label = "LAYER_TAP_TO_0";
            bindings = <&mo>, <&to_layer_0>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
        };

        scroll_up_down: behavior_sensor_rotate_mouse_wheel_up_down {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;

            // 追加: スクロールのタップ時間を設定 (20ms)

            tap-ms = <20>;
        };

        scroll_left_right: behavior_sensor_rotate_mouse_wheel_left_right {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_LEFT>, <&msc SCRL_RIGHT>;

            tap-ms = <20>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp Q             &kp W         &kp E         &kp R             &kp T                                              &kp Y        &kp U  &kp I      &kp O    &kp P
&kp A             &kp S         &kp D         &kp F             &kp G        &to_layer_0 LS(LG(S))      &kp MINUS  &kp H        &kp J  &lt 5 K    &kp L    &kp RSHFT
&mt LEFT_SHIFT Z  &kp X         &kp C         &kp V             &kp B        &kp APOS                   &kp EQUAL  &kp N        &kp M  &kp COMMA  &kp DOT  &kp SEMI
&kp LCTRL         &kp LEFT_WIN  &kp LEFT_ALT  &lt 6 LANGUAGE_2  &lt 2 SPACE  &lt 1 LANGUAGE_1           &kp BSPC   &lt 2 ENTER                             &kp FSLH
            >;

            sensor-bindings = <&scroll_up_down>;
        };

        FUNCTION {
            bindings = <
&kp ESC   &kp F9  &kp F10            &kp F11  &kp F12                           &kp LC(LS(P))  &kp LC(LS(K))  &kp LC(GRAVE)  &kp LC(B)  &kp LC(LS(E))
&kp HOME  &kp F5  &kp F6             &kp F7   &kp F8   &kp LC(DEL)      &trans  &kp LA(LS(F))  &kp LC(D)      &kp LC(F)      &kp LC(H)  &trans
&kp END   &kp F1  &kp F2             &kp F3   &kp F4   &trans           &trans  &kp C_MUTE     &kp C_VOL_DN   &kp C_VOL_UP   &kp C_PP   &kp C_NEXT
&trans    &trans  &lt 3 RIGHT_SHIFT  &trans   &trans   &trans           &trans  &trans                                                  &trans
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP>;
        };

        NUM {
            bindings = <
&kp TAB    &kp N7        &kp N8        &kp N9  &kp N0                           &kp K_COPY  &kp LEFT   &kp UP    &kp RIGHT  &kp K_PASTE
&trans     &kp N4        &kp N5        &kp N6  &kp SEMI   &trans      &trans    &kp GRAVE   &mkp MB1   &kp DOWN  &mkp MB2   &mkp MB3
&trans     &kp N1        &kp N2        &kp N3  &kp MINUS  &trans      &trans    &kp APOS    &kp EQUAL  &kp LBKT  &kp RBKT   &kp GRAVE
&kp LCTRL  &kp LEFT_WIN  &kp LEFT_ALT  &trans  &trans     &trans      &mkp MB4  &mkp MB5                                    &kp RSHFT
            >;

            sensor-bindings = <&inc_dec_kp LC(LS(TAB)) LC(TAB)>;
        };

        layer_6 {
            bindings = <
&trans  &trans  &trans  &trans  &trans                           &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4
&trans  &trans  &trans  &trans  &trans  &trans      &trans       &to 0         &to 7         &trans        &trans        &trans
&trans  &none   &none   &none   &trans  &trans      &bootloader  &trans        &trans        &trans        &trans        &bt BT_CLR
&trans  &trans  &trans  &trans  &trans  &trans      &trans       &trans                                                  &bt BT_CLR_ALL
            >;
        };

        MOUSE {
            bindings = <
&trans  &trans  &trans  &trans  &trans                      &trans  &trans             &trans  &trans             &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &mkp_exit_AML MB1  &trans  &mkp_exit_AML MB2  &mkp_exit_AML MB3
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans             &trans  &trans             &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans                                                &trans
            >;

            sensor-bindings = <&inc_dec_kp LC(MINUS) LC(EQUAL)>;
        };

        SCROLL {
            bindings = <
&trans        &kp LC(LS(TAB))  &kp LC(T)     &kp LC(TAB)  &trans                      &trans  &trans  &trans  &trans  &trans
&kp LA(LEFT)  &kp LC(W)        &kp LC(L)     &kp LC(R)    &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans        &kp LC(Z)        &kp LC(Y)     &kp LC(V)    &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&kp LCTRL     &kp LEFT_WIN     &kp LEFT_ALT  &trans       &trans  &trans      &trans  &trans                          &trans
            >;

            sensor-bindings = <&scroll_left_right>;
        };

        SYMBOL {
            bindings = <
&arrow      &kp AMPERSAND    &kp ASTERISK  &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS                                 &kp BSLH           &trans     &kp LEFT_BRACE    &kp RIGHT_BRACE    &trans
&fat_arrow  &kp DOLLAR       &kp PERCENT   &kp CARET             &kp COLON              &not_eq      &trans            &kp TILDE          &kp SLASH  &kp LEFT_BRACKET  &kp RIGHT_BRACKET  &kp RIGHT_SHIFT
&trans      &kp EXCLAMATION  &kp AT_SIGN   &kp HASH              &kp UNDERSCORE         &trans       &kp SINGLE_QUOTE  &kp DOUBLE_QUOTES  &kp PLUS   &kp LESS_THAN     &kp GREATER_THAN   &kp COLON
&kp LCTRL   &kp LEFT_WIN     &kp LEFT_ALT  &trans                &trans                 &trans       &trans            &trans                                                             &kp QUESTION
            >;

            sensor-bindings = <&inc_dec_kp PAGE_UP PAGE_DOWN>;
        };

        // ── Mac モード用レイヤー ──────────────────────────────────────────────
        // BTレイヤー（layer 3）の J=&to 0（Win）/ K=&to 7（Mac）で切り替え

        MAC_DEFAULT {
            bindings = <
&kp Q             &kp W         &kp E         &kp R             &kp T                                                 &kp Y        &kp U  &kp I      &kp O    &kp P
&kp A             &kp S         &kp D         &kp F             &kp G        &to_mac_layer LG(LS(N4))      &kp MINUS  &kp H        &kp J  &lt 9 K    &kp L    &kp RSHFT
&mt LEFT_SHIFT Z  &kp X         &kp C         &kp V             &kp B        &kp APOS                      &kp EQUAL  &kp N        &kp M  &kp COMMA  &kp DOT  &kp SEMI
&kp LCTRL         &kp LEFT_WIN  &kp LEFT_ALT  &lt 6 LANGUAGE_2  &lt 2 SPACE  &lt 8 LANGUAGE_1              &kp BSPC   &lt 2 ENTER                             &kp FSLH
            >;

            sensor-bindings = <&scroll_up_down>;
        };

        MAC_FUNCTION {
            bindings = <
&kp ESC   &kp F9  &kp F10            &kp F11  &kp F12                           &kp LG(LS(P))  &kp LG(LS(K))  &kp LC(GRAVE)  &kp LG(B)      &kp LG(LS(E))
&kp HOME  &kp F5  &kp F6             &kp F7   &kp F8   &kp LA(DEL)      &trans  &kp LA(LS(F))  &kp LG(D)      &kp LG(F)      &kp LA(LG(F))  &trans
&kp END   &kp F1  &kp F2             &kp F3   &kp F4   &trans           &trans  &kp C_MUTE     &kp C_VOL_DN   &kp C_VOL_UP   &kp C_PP       &kp C_NEXT
&trans    &trans  &lt 3 RIGHT_SHIFT  &trans   &trans   &trans           &trans  &trans                                                      &trans
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP>;
        };

        MAC_SCROLL {
            bindings = <
&trans        &kp LC(LS(TAB))  &kp LG(T)      &kp LC(TAB)  &trans                      &trans  &trans  &trans  &trans  &trans
&kp LG(LBKT)  &kp LG(W)        &kp LG(L)      &kp LG(R)    &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans        &kp LG(Z)        &kp LG(LS(Z))  &kp LG(V)    &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&kp LCTRL     &kp LEFT_WIN     &kp LEFT_ALT   &trans       &trans  &trans      &trans  &trans                          &trans
            >;

            sensor-bindings = <&scroll_left_right>;
        };
    };
};
